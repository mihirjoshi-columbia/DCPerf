# 0009-tao_bench_client_interval_reporting.diff
#
# Adds a `--window=<sec>` flag to tao_bench_client (memtier fork) that
# enables per-window interval reporting of throughput and client-observed
# latency percentiles. When --window is set, tao_bench_client emits a
# single line per window to stdout in the form:
#
#   INTERVAL t=<sec> set_qps=<...> get_qps=<...> hit_rate=<...> \
#            avg_us=<...> p50_us=<...> p99_us=<...> p999_us=<...> max_us=<...>
#
# Default (window=0) preserves the previous end-of-run-only behavior.
#
# This patch is applied by packages/tao_bench/install_tao_bench_*.sh
# AFTER 0005-tao_bench_client_memtier_20230615.diff.
diff --git a/memtier_benchmark.cpp b/memtier_benchmark.cpp
--- a/memtier_benchmark.cpp
+++ b/memtier_benchmark.cpp
@@ -407,6 +407,7 @@ static int config_parse_args(int argc, char *argv[], struct benchmark_config *cf
         o_tao_num_t_db,
         o_tao_num_t_coherence,
         o_tao_num_c_coherence,
         o_tao_key_bytes,
+        o_window,
         o_hdr_file_prefix,
         o_help
     };
@@ -475,6 +476,7 @@ static int config_parse_args(int argc, char *argv[], struct benchmark_config *cf
         { "threads-db",                 1, 0, o_tao_num_t_db },
         { "threads-coherence",          1, 0, o_tao_num_t_coherence},
         { "clients-coherence",          1, 0, o_tao_num_c_coherence},
         { "key-bytes",                  1, 0, o_tao_key_bytes},
+        { "window",                     1, 0, o_window },
         { NULL,                         0, 0, 0 }
     };
 
@@ -867,6 +869,15 @@ static int config_parse_args(int argc, char *argv[], struct benchmark_config *cf
                     break;
                 case o_tao_key_bytes:
                     cfg->key_bytes = (unsigned int) strtoul(optarg, &endptr, 10);
                     if (!(cfg->key_bytes > 0) || !endptr || *endptr != '\0') {
                         fprintf(stderr, "error: Number of bytes in the keys.\n");
                         return -1;
                     }
                     break;
+                case o_window:
+                    cfg->window = (int) strtol(optarg, &endptr, 10);
+                    if (cfg->window < 0 || !endptr || *endptr != '\0') {
+                        fprintf(stderr, "error: --window must be >= 0 (seconds).\n");
+                        return -1;
+                    }
+                    break;
             default:
                     return -1;
                     break;
@@ -1116,6 +1127,28 @@ run_stats run_benchmark(int run_id, benchmark_config* cfg, object_generator* obj
             if (!(*i)->m_finished)
                 active_threads++;
 
             if (!(*i)->m_simulates_coherency) {
                 total_ops += (*i)->m_cg->get_total_ops();
                 total_bytes += (*i)->m_cg->get_total_bytes();
                 total_latency += (*i)->m_cg->get_total_latency();
                 thread_counter++;
                 float factor = ((float)(thread_counter - 1) / thread_counter);
                 duration =  factor * duration +  (float)(*i)->m_cg->get_duration_usec() / thread_counter;
             }
         }
+
+        /* TaoBench interval reporting tick. We compute the time elapsed
+         * since the test started (cur_duration is in usec) and, if a
+         * full window has elapsed since the last INTERVAL line, snapshot
+         * the current totals and emit a delta-based line on stdout.
+         *
+         * The very first window-boundary capture only establishes a
+         * baseline (s_have_baseline) and does NOT print. This effectively
+         * suppresses the warmup window inside the execution phase, so
+         * percentiles always reflect a fully-warm window of traffic.
+         * The Python orchestrator additionally avoids passing --window on
+         * the warmup-phase invocation; this in-binary gate is defense in
+         * depth so a stray --window on warmup still produces no output. */
+        if (cfg->window > 0) {
+            static run_stats::interval_snapshot s_prev;
+            static bool s_have_baseline = false;
+            static double s_next_emit_sec = (double)cfg->window;
+            double now_sec = double(cur_duration) / 1.0e6;
+            if (now_sec >= s_next_emit_sec) {
+                run_stats::interval_snapshot cur =
+                    stats.capture_interval_snapshot(now_sec);
+                if (s_have_baseline) {
+                    stats.format_interval_line(std::cout, s_prev, cur);
+                    std::cout.flush();
+                } else {
+                    s_have_baseline = true;
+                }
+                s_prev = cur;
+                s_next_emit_sec += (double)cfg->window;
+            }
+        }
+
         unsigned long int cur_ops = total_ops-prev_ops;
@@ -926,6 +937,8 @@ void usage() {
             "      --clients-coherence=NUMBER Number of clients per thread for simulating tao consistency (default: 1)\n"
             "      --key-bytes=NUMBER         Number of bytes in the key (default: 0 - that means prefix would be 'memtier-')\n"
+            "      --window=SECS              If > 0, emit per-window INTERVAL latency/throughput\n"
+            "                                 lines on stdout every SECS seconds (default: 0 = off)\n"
             "      --test-time=SECS           Number of seconds to run the test\n"
             "      --ratio=RATIO              Set:Get ratio (default: 1:10)\n"
