diff --git a/src/_pylibmcmodule.h b/src/_pylibmcmodule.h
index cee9772..d28dec6 100644
--- a/src/_pylibmcmodule.h
+++ b/src/_pylibmcmodule.h
@@ -52,6 +52,16 @@
 typedef ssize_t Py_ssize_t;
 #endif
 
+/* Python 3.4+ PyMem_New/PyMem_Free require the GIL. Use Raw variants for
+ * allocations in GIL-free sections (e.g. inside Py_BEGIN_ALLOW_THREADS). */
+#if PY_VERSION_HEX >= 0x03040000
+#  define PyMem_RawNew(type, nelem) ((type *)PyMem_RawMalloc((nelem)*sizeof(type)))
+#  define PyMem_RawDel(ptr) PyMem_RawFree(ptr)
+#else
+#  define PyMem_RawNew PyMem_New
+#  define PyMem_RawDel(ptr) PyMem_Del(ptr)
+#endif
+
 /* Server types. */
 #define PYLIBMC_SERVER_TCP   (1 << 0)
 #define PYLIBMC_SERVER_UDP   (1 << 1)
